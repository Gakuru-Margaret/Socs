# ══════════════════════════════════════════════
#  SOCS — Environment Variables
#  Copy this to .env and fill in your values
#  NEVER commit .env to version control
# ══════════════════════════════════════════════

# ── SERVER ──────────────────────────────────
NODE_ENV=development
PORT=3000

# ── DATABASE ─────────────────────────────────
# Get this from your PostgreSQL provider
# Local:   postgresql://username:password@localhost:5432/socs_db
# Render:  postgresql://user:pass@host/socs_db?sslmode=require
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/socs_db

# ── JWT AUTH ─────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string_at_least_64_chars
JWT_EXPIRES=8h

# ── FRONTEND URL ─────────────────────────────
# For CORS — set to your frontend domain in production
FRONTEND_URL=http://localhost:3000

# ── UPLOADS ──────────────────────────────────
# Max upload size (bytes). Default 5MB = 5242880
MAX_UPLOAD_SIZE=5242880
